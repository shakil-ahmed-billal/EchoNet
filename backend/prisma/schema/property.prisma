model Property {
  id          String         @id @default(uuid())
  ownerId     String
  agentId     String?
  title       String
  description String         @db.Text
  price       Decimal
  priceUnit   String         @default("TOTAL") // TOTAL or PER_MONTH
  listingType ListingType    @default(SALE)
  category    String // Apartment, House, Commercial, Land
  city        String
  area        String
  address     String
  latitude    Float?
  longitude   Float?
  status      PropertyStatus @default(PENDING)
  viewCount   Int            @default(0)
  deletedAt   DateTime?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  owner User          @relation("PropertyOwner", fields: [ownerId], references: [id])
  agent AgentProfile? @relation(fields: [agentId], references: [id])

  details   PropertyDetail?
  images    PropertyImage[]
  amenities PropertyAmenity[]
  bookings  Booking[]
  enquiries PropertyEnquiry[]
  savedBy   SavedProperty[]
  reviews   PropertyReview[]

  @@index([status, deletedAt])
  @@index([listingType])
  @@index([city])
}

enum ListingType {
  RENT
  SALE
  LEASE
}

enum PropertyStatus {
  PENDING
  ACTIVE
  INACTIVE
  REJECTED
  SOLD
  RENTED
}

model PropertyDetail {
  id            String    @id @default(uuid())
  propertyId    String    @unique
  bedrooms      Int?
  bathrooms     Int?
  areaSqft      Int
  floorNo       Int?
  totalFloors   Int?
  parking       Int?      @default(0)
  facing        String?
  furnished     String? // NONE, SEMI, FULL
  yearBuilt     Int?
  availableFrom DateTime?
  property      Property  @relation(fields: [propertyId], references: [id], onDelete: Cascade)
}

model PropertyImage {
  id         String   @id @default(uuid())
  propertyId String
  url        String
  publicId   String?
  isCover    Boolean  @default(false)
  order      Int      @default(0)
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
}

model PropertyAmenity {
  id         String   @id @default(uuid())
  propertyId String
  name       String // e.g., Gas, Lift, Security
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
}

model Booking {
  id         String        @id @default(uuid())
  propertyId String
  userId     String // visitor
  visitDate  DateTime
  visitTime  String
  message    String?       @db.Text
  status     BookingStatus @default(PENDING)
  createdAt  DateTime      @default(now())
  property   Property      @relation(fields: [propertyId], references: [id])
  user       User          @relation("UserBookings", fields: [userId], references: [id])
}

enum BookingStatus {
  PENDING
  CONFIRMED
  DONE
  CANCELLED
  NO_SHOW
}

model PropertyEnquiry {
  id         String   @id @default(uuid())
  propertyId String
  senderId   String
  message    String   @db.Text
  phone      String?
  isRead     Boolean  @default(false)
  createdAt  DateTime @default(now())
  property   Property @relation(fields: [propertyId], references: [id])
  sender     User     @relation("UserEnquiries", fields: [senderId], references: [id])
}

model AgentProfile {
  id            String     @id @default(uuid())
  userId        String     @unique
  licenseNo     String
  agencyName    String?
  totalListings Int        @default(0)
  totalSales    Int        @default(0)
  isVerified    Boolean    @default(false)
  bio           String?    @db.Text
  createdAt     DateTime   @default(now())
  user          User       @relation("UserAgent", fields: [userId], references: [id])
  properties    Property[]
}

model SavedProperty {
  id         String   @id @default(uuid())
  userId     String
  propertyId String
  createdAt  DateTime @default(now())
  user       User     @relation("UserSavedProperties", fields: [userId], references: [id])
  property   Property @relation(fields: [propertyId], references: [id])

  @@unique([userId, propertyId])
}

model PropertyReview {
  id         String   @id @default(uuid())
  propertyId String
  reviewerId String
  rating     Int
  comment    String?  @db.Text
  createdAt  DateTime @default(now())
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  reviewer   User     @relation("UserPropertyReviews", fields: [reviewerId], references: [id])

  @@unique([reviewerId, propertyId])
}
